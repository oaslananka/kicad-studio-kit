{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "build",
      "label": "npm: build",
      "problemMatcher": "$tsc-watch"
    },
    {
      "type": "npm",
      "script": "pretest",
      "label": "npm: pretest",
      "problemMatcher": "$tsc"
    },
    {
      "type": "npm",
      "script": "test:unit",
      "label": "npm: test:unit",
      "problemMatcher": []
    },
    {
      "label": "Start kicad-mcp-pro (HTTP)",
      "type": "shell",
      "command": "uvx",
      "args": ["kicad-mcp-pro", "--transport", "http", "--port", "27185"],
      "isBackground": true,
      "problemMatcher": [],
      "options": {
        "env": {
          "KICAD_MCP_PROJECT_DIR": "${workspaceFolder}",
          "KICAD_MCP_PROFILE": "analysis",
          "KICAD_MCP_OPERATING_MODE": "readonly"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
