{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oaslananka.github.io/kicad-studio-kit/schemas/mcp-server-health.schema.json",
  "title": "MCP server health and version contract",
  "description": "Health/version payload advertised by kicad-mcp-pro without VS Code or Python implementation details.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "server",
    "version",
    "status",
    "mcpProtocolVersion",
    "toolSchemaVersion",
    "transport",
    "kicad",
    "diagnostics"
  ],
  "properties": {
    "schemaVersion": {
      "$ref": "#/$defs/semver"
    },
    "server": {
      "const": "kicad-mcp-pro"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["ok", "degraded", "error"]
    },
    "mcpProtocolVersion": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "toolSchemaVersion": {
      "$ref": "#/$defs/semver"
    },
    "transport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "endpoint"],
      "properties": {
        "type": {
          "enum": ["stdio", "streamable-http", "sse"]
        },
        "endpoint": {
          "type": ["string", "null"]
        }
      }
    },
    "kicad": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cliFound", "cliVersion", "ipcAvailable"],
      "properties": {
        "cliFound": {
          "type": "boolean"
        },
        "cliVersion": {
          "type": ["string", "null"]
        },
        "ipcAvailable": {
          "type": "boolean"
        }
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    }
  },
  "x-kicad-studio-kit": {
    "trackingIssue": "OASLANA-52",
    "schemaVersion": "1.0.0"
  }
}
