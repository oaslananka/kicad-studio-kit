{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oaslananka.github.io/kicad-studio-kit/schemas/extension-active-context.schema.json",
  "title": "KiCad Studio active context payload",
  "description": "Product-neutral IDE context payload pushed from the extension to MCP tools.",
  "type": "object",
  "additionalProperties": false,
  "required": ["fileType", "drcErrors"],
  "properties": {
    "schemaVersion": {
      "$ref": "#/$defs/semver"
    },
    "activeFile": {
      "type": ["string", "null"]
    },
    "fileType": {
      "enum": ["schematic", "pcb", "other"]
    },
    "drcErrors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "projectId": {
      "type": "string"
    },
    "projectName": {
      "type": "string"
    },
    "projectRoot": {
      "type": "string"
    },
    "projectFile": {
      "type": "string"
    },
    "selectedNet": {
      "type": "string"
    },
    "selectedReference": {
      "type": "string"
    },
    "activeVariant": {
      "type": "string"
    },
    "activeSheetPath": {
      "type": "string"
    },
    "visibleLayers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "kicadVersion": {
      "type": "string"
    },
    "designBlocks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cursorPosition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line", "character"],
      "properties": {
        "line": {
          "type": "integer",
          "minimum": 0
        },
        "character": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "selectedArea": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x1", "y1", "x2", "y2"],
      "properties": {
        "x1": {
          "type": "number"
        },
        "y1": {
          "type": "number"
        },
        "x2": {
          "type": "number"
        },
        "y2": {
          "type": "number"
        }
      }
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    }
  },
  "x-kicad-studio-kit": {
    "trackingIssue": "OASLANA-52",
    "schemaVersion": "1.0.0"
  }
}
