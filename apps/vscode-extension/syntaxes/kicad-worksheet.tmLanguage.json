{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "KiCad Worksheet",
  "scopeName": "source.kicad.wks",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#boolean" },
    { "include": "#keywords" },
    { "include": "#variableRef" },
    { "include": "#parens" }
  ],
  "repository": {
    "comment": {
      "patterns": [{ "name": "comment.line.kicad", "match": "#.*$" }]
    },
    "string": {
      "patterns": [
        {
          "name": "string.quoted.double.kicad",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "match": "\\\\.", "name": "constant.character.escape.kicad" }
          ]
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.kicad",
          "match": "(?<![A-Za-z0-9_])-?\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "boolean": {
      "patterns": [
        {
          "name": "constant.language.kicad",
          "match": "\\b(?:yes|no|true|false|center|left|right|top|bottom|middle)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.kicad",
          "match": "\\b(?:kicad_wks|page_layout|drawing_sheet|version|generator|generator_version|setup|tbtext)\\b"
        },
        {
          "name": "keyword.other.kicad",
          "match": "\\b(?:line|rect|polygon|bitmap|comment|textsize|linewidth|textlinewidth|left_margin|right_margin|top_margin|bottom_margin|start|end|pos|name|pts|xy|font|bold|italic|size|thickness|justify|repeat|incrx|incry|rotate|maxlen|maxheight|ltcorner|lbcorner|rtcorner|rbcorner)\\b"
        }
      ]
    },
    "variableRef": {
      "patterns": [
        { "name": "variable.other.kicad", "match": "\\$\\{[A-Za-z0-9_#]+\\}" }
      ]
    },
    "parens": {
      "patterns": [{ "name": "punctuation.bracket.kicad", "match": "[()]" }]
    }
  }
}
