{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "KiCad PCB",
  "scopeName": "source.kicad.pcb",
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#string"
    },
    {
      "include": "#uuid"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#controlKeywords"
    },
    {
      "include": "#otherKeywords"
    },
    {
      "include": "#layers"
    },
    {
      "include": "#parens"
    }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.kicad",
          "match": "#.*$"
        }
      ]
    },
    "string": {
      "patterns": [
        {
          "name": "string.quoted.double.kicad",
          "begin": "\"",
          "end": "\""
        }
      ]
    },
    "uuid": {
      "patterns": [
        {
          "name": "variable.other.kicad",
          "match": "\\b[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.kicad",
          "match": "(?<![A-Za-z0-9_])-?\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.kicad",
          "match": "\\b(?:yes|no|true|false|center|left|right|top|bottom|middle)\\b"
        }
      ]
    },
    "controlKeywords": {
      "patterns": [
        {
          "name": "keyword.control.kicad",
          "match": "\\b(?:kicad_pcb|general|setup|layers|net|footprint|pad|segment|via|zone|gr_line|gr_arc|gr_circle|gr_rect|gr_poly|gr_curve|gr_text|dimension|target|group)\\b"
        }
      ]
    },
    "otherKeywords": {
      "patterns": [
        {
          "name": "keyword.other.kicad",
          "match": "\\b(?:clearance|zone_clearance|trace_width|drill|shape|offset|net_name|tstamp|thermal_gap|thermal_bridge_width|filled_polygon|fill_segments|hatch|connect_pads|min_thickness|pad_to_die_length|at|size|angle|mirror|fill|stroke|color|effects|font|justify|reference|value|footprint|uuid|property|pin|number|name|layer|start|end|mid|arc|circle|rect|polyline|bezier|image)\\b"
        }
      ]
    },
    "layers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.kicad",
          "match": "\\b(?:F\\.Cu|B\\.Cu|\\*\\.Cu|In\\d+\\.Cu)\\b"
        },
        {
          "name": "entity.name.tag.kicad",
          "match": "\\b(?:F\\.SilkS|B\\.SilkS|F\\.Mask|B\\.Mask|Edge\\.Cuts|F\\.Fab|B\\.Fab|F\\.Courtyard|B\\.Courtyard|User\\.[A-Za-z0-9_]+)\\b"
        }
      ]
    },
    "parens": {
      "patterns": [
        {
          "name": "punctuation.bracket.kicad",
          "match": "[()]"
        }
      ]
    }
  }
}
