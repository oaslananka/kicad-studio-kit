{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "KiCad Symbol Library",
  "scopeName": "source.kicad.sym",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#uuid" },
    { "include": "#number" },
    { "include": "#boolean" },
    { "include": "#controlKeywords" },
    { "include": "#pinTypes" },
    { "include": "#pinDirections" },
    { "include": "#otherKeywords" },
    { "include": "#libraryHeader" },
    { "include": "#symbolName" },
    { "include": "#propertyKey" },
    { "include": "#support" },
    { "include": "#parens" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.kicad",
          "match": "#.*$"
        }
      ]
    },
    "string": {
      "patterns": [
        {
          "name": "string.quoted.double.kicad",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.kicad",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "uuid": {
      "patterns": [
        {
          "name": "variable.other.kicad",
          "match": "\\b[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}\\b"
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.kicad",
          "match": "(?<![A-Za-z0-9_])-?\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "boolean": {
      "patterns": [
        {
          "name": "constant.language.kicad",
          "match": "\\b(?:yes|no|true|false|center|left|right|top|bottom|middle|mirror|normal|italic|bold)\\b"
        }
      ]
    },
    "controlKeywords": {
      "comment": "Top-level structural nodes specific to .kicad_sym",
      "patterns": [
        {
          "name": "keyword.control.kicad",
          "match": "\\b(?:kicad_symbol_lib|symbol|pin|rectangle|polyline|circle|arc|bezier|text|text_box)\\b"
        }
      ]
    },
    "pinTypes": {
      "comment": "Electrical pin types — appear as the 3rd atom inside a (pin ...) node",
      "patterns": [
        {
          "name": "support.type.pin-type.kicad",
          "match": "\\b(?:input|output|bidirectional|tri_state|passive|power_input|power_output|open_collector|open_emitter|unconnected|no_connect|free)\\b"
        }
      ]
    },
    "pinDirections": {
      "comment": "Pin orientation tokens R/L/U/D used inside (direction ...)",
      "patterns": [
        {
          "name": "support.type.pin-direction.kicad",
          "match": "(?<=\\(direction\\s+)\\b[RLUD]\\b"
        }
      ]
    },
    "otherKeywords": {
      "comment": "Attribute / property keywords inside symbol nodes",
      "patterns": [
        {
          "name": "keyword.other.kicad",
          "match": "\\b(?:at|size|angle|mirror|fill|stroke|color|effects|font|justify|reference|value|footprint|datasheet|description|keywords|uuid|property|number|name|layer|start|end|mid|length|direction|offset|width|type|style|hide|demorgan|unit|pin_names|pin_numbers|in_bom|on_board|extends|generator|generator_version|version)\\b"
        }
      ]
    },
    "libraryHeader": {
      "comment": "The root library node identifier",
      "patterns": [
        {
          "name": "entity.name.namespace.kicad",
          "match": "(?<=\\(kicad_symbol_lib\\s[^)]*generator\\s)\"[^\"]+\""
        }
      ]
    },
    "symbolName": {
      "comment": "Symbol identifier — first unquoted/quoted atom after (symbol",
      "patterns": [
        {
          "name": "entity.name.type.kicad",
          "match": "(?<=\\(symbol\\s)(?:\"[^\"]*\"|[^\\s()\"]+)"
        }
      ]
    },
    "propertyKey": {
      "comment": "Property names — first string after (property",
      "patterns": [
        {
          "name": "entity.other.attribute-name.kicad",
          "match": "(?<=\\(property\\s)\"[^\"]*\""
        }
      ]
    },
    "support": {
      "comment": "Net / electrical support tokens",
      "patterns": [
        {
          "name": "support.type.kicad",
          "match": "\\b(?:net|netname|pin_type|line|filled|background|none)\\b"
        }
      ]
    },
    "parens": {
      "patterns": [
        {
          "name": "punctuation.bracket.kicad",
          "match": "[()]"
        }
      ]
    }
  }
}
