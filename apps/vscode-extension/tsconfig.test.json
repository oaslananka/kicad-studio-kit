{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "outDir": "out",
    "sourceMap": true,
    "rootDir": ".",
    "types": ["node", "vscode", "mocha"]
  },
  "include": [
    "test/runTest.ts",
